<idea-plugin>
    <id>io.github.jacekgajek.koog-strategy-graph</id>
    <name>Koog Strategy Graph</name>
    <vendor email="jacek.s.gajek@gmail.com" url="https://github.com/jacekgajek">Jacek Gajek</vendor>

    <description><![CDATA[
        <p>Visualization for <a href="https://github.com/JetBrains/koog">Koog</a>
        agent <code>strategy { ... }</code> DSL blocks.</p>
        <p>A gutter icon next to every recognized <code>strategy(...)</code> call
        renders the strategy as a Mermaid state diagram in the <em>Koog Strategy</em>
        tool window. The diagram is produced by Koog's own
        <code>MermaidDiagramGenerator</code>: the plugin lifts the
        <code>strategy { }</code> snippet into a temporary program, compiles it
        against your module, runs it, and displays the result &mdash; so the graph
        always matches Koog's real interpretation of the strategy. This requires the
        code to compile.</p>
    ]]></description>

    <change-notes><![CDATA[
        <h3>0.1.0</h3>
        <ul>
            <li>Initial release: gutter icon + popup graph.</li>
        </ul>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="com.intellij">
        <codeInsight.lineMarkerProvider
            language="kotlin"
            implementationClass="io.github.jacekgajek.koog.graph.marker.StrategyLineMarkerProvider"/>
        <toolWindow
            id="Koog Strategy"
            anchor="right"
            canCloseContents="true"
            icon="AllIcons.Toolwindows.ToolWindowHierarchy"
            factoryClass="io.github.jacekgajek.koog.graph.tool.KoogGraphToolWindowFactory"/>
    </extensions>

    <!-- Both K1 and K2 modes of the Kotlin plugin are supported. We only walk
         syntactic PSI (KtCallExpression, KtProperty, KtBinaryExpression) and
         never call the Analysis API, so the same code runs unchanged in either
         mode. Without this declaration K2 refuses to load the plugin. -->
    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK1="true" supportsK2="true"/>
    </extensions>
</idea-plugin>
