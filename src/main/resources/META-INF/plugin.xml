<idea-plugin>
    <id>io.github.jacekgajek.koog-strategy-graph</id>
    <name>Koog Strategy Graph</name>
    <!-- TODO before publishing: set a real contact email here. The Marketplace
         enforces a deliverable address; the placeholder will be rejected. -->
    <vendor email="jacek.gajek@example.com" url="https://github.com/jacekgajek">jacekgajek</vendor>

    <description><![CDATA[
        <p>Visualization for <a href="https://github.com/JetBrains/koog">Koog</a>
        agent <code>strategy { ... }</code> DSL blocks.</p>
        <p>A gutter icon next to every recognized <code>strategy(...)</code> call
        loads a layered graph of all <code>val x by nodeXxx()</code> nodes and
        <code>edge(a forwardTo b)</code> connections in that block into the
        <em>Koog Strategy</em> tool window. Layout is computed by the Eclipse
        Layout Kernel; rendering is pure Swing &mdash; no external tools are
        required.</p>
    ]]></description>

    <change-notes><![CDATA[
        <h3>0.1.0</h3>
        <ul>
            <li>Initial release: gutter icon + popup graph.</li>
        </ul>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="com.intellij">
        <codeInsight.lineMarkerProvider
            language="kotlin"
            implementationClass="io.github.jacekgajek.koog.graph.marker.StrategyLineMarkerProvider"/>
        <toolWindow
            id="Koog Strategy"
            anchor="right"
            icon="AllIcons.Toolwindows.ToolWindowHierarchy"
            factoryClass="io.github.jacekgajek.koog.graph.tool.KoogGraphToolWindowFactory"/>
    </extensions>
</idea-plugin>
